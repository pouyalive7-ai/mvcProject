@model FahrzeugLoeschenModel
<p>Wollen Sie das Fahrzeug wirklich löschen?</p>
<div>
    <h4>@Model.Name</h4>
    <form asp-asp-controller="Fahrzeug" asp-action="Loeschen">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Löschen" class="btn btn-danger" />
        @Html.ActionLink("Abbrechen", "Index", "Fahrzeug", null, new { @class = "btn btn-secondary" })
    </form>
</div>  